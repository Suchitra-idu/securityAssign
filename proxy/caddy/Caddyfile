{
    admin off
    auto_https disable_redirects
    order coraza_waf first
    order rate_limit before reverse_proxy

    log default {
        output stdout
        format console
        level INFO
    }
}

# HTTP -> HTTPS redirect
:80 {
    redir https://{host}{uri} permanent
}

# Client-facing HTTPS. Caddy generates a local CA and issues a cert for
# localhost. Browsers will warn until the CA is trusted; curl -k works.
# In production this becomes a real hostname with Let's Encrypt.
localhost {
    tls internal

    # Web Application Firewall. Runs in DetectionOnly during the demo so
    # a mis-tuned rule cannot lock legitimate traffic out; switch to
    # SecRuleEngine On in coraza.conf once the OWASP CRS is tuned for
    # our JSON API.
    coraza_waf {
        directives `
            Include /etc/coraza/coraza.conf
            Include /etc/coraza/crs-setup.conf
            Include /etc/coraza/rules/*.conf
        `
    }

    # Per-client rate limit. 300/min is comfortable for real interactive
    # UI use (a user clicking through accounts + transfers easily produces
    # 60+ requests in a minute after Playwright/browser cache misses) while
    # still catching bruteforce or credential-stuffing loops which hit
    # thousands per minute. Tighten to 60 for headless-API deployments.
    rate_limit {
        zone per_ip {
            key {remote_host}
            events 300
            window 1m
        }
    }

    # Banking is prefixed on /banking/* so both services live behind the
    # same host without route collisions. Prefix is stripped before the
    # upstream sees the request.
    handle_path /banking/* {
        reverse_proxy https://banking:8000 {
            transport http {
                tls_insecure_skip_verify
            }
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    # Auth API on explicit paths. Only these five routes exist on auth;
    # anything else falls through to the static UI. Keeping the list
    # explicit means a typo cannot silently proxy random paths into the
    # auth container.
    @auth_paths path /register /login /refresh /public-key /health
    handle @auth_paths {
        reverse_proxy https://auth:8000 {
            # Auth serves a self-signed cert baked into its image (CN=auth).
            # Caddy trusts it explicitly rather than validating against a CA
            # bundle; mTLS is the production upgrade per DEV_GUIDE.
            transport http {
                tls_insecure_skip_verify
            }
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    # Static UI on everything else. Clean URLs: /app resolves to
    # /srv/ui/app.html, /styles.css to /srv/ui/styles.css, etc.
    # Anything else falls through to index.html (the login page).
    handle {
        root * /srv/ui
        try_files {path} {path}.html /index.html
        file_server
    }
}
