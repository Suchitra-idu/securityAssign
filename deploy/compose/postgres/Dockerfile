FROM postgres:16-alpine

# TLS material generated by deploy/compose/tls/generate.sh on the host.
# The build context is deploy/compose, so paths below are relative to that.
COPY tls/server.crt /var/lib/postgresql/server.crt
COPY tls/server.key /var/lib/postgresql/server.key
COPY tls/ca.crt     /var/lib/postgresql/ca.crt
COPY postgres/pg_hba.conf /var/lib/postgresql/pg_hba.conf

# Postgres refuses to start if the key isn't owned by the running user
# (postgres uid=70 in the alpine image) and mode <= 0600.
RUN chown postgres:postgres \
        /var/lib/postgresql/server.crt \
        /var/lib/postgresql/server.key \
        /var/lib/postgresql/ca.crt \
        /var/lib/postgresql/pg_hba.conf \
 && chmod 600 /var/lib/postgresql/server.key \
              /var/lib/postgresql/pg_hba.conf \
 && chmod 644 /var/lib/postgresql/server.crt \
              /var/lib/postgresql/ca.crt
