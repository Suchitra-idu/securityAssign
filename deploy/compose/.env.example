# Postgres
POSTGRES_USER=auth
POSTGRES_PASSWORD=replace-me-with-a-real-secret
POSTGRES_DB=auth

# Auth service — signing keypair
# ----------------------------------------------------------------------
# Two options: inline PEM in env, or a path to a mounted file. In
# production prefer the file (Docker secret, mounted at /run/secrets/…).
#
# Generate a fresh keypair:
#   openssl genpkey -algorithm ED25519 -out priv.pem
#   openssl pkey -in priv.pem -pubout -out pub.pem
#
# Or from Python:
#   python -c "from shared_security.tokens import generate_signing_keypair; \
#              priv, pub = generate_signing_keypair(); print('PRIV=' + repr(priv)); print('PUB=' + repr(pub))"
#
# --- Option A: inline (simplest for dev) ---
AUTH_SIGNING_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
AUTH_SIGNING_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
#
# --- Option B: file path (production) ---
# Uncomment and remove the inline vars above. The docker-compose.yml has
# a commented `secrets:` block showing how to mount the files.
# AUTH_SIGNING_PRIVATE_KEY_PATH=/run/secrets/auth_signing_private_key
# AUTH_SIGNING_PUBLIC_KEY_PATH=/run/secrets/auth_signing_public_key

# TTLs (optional — defaults shown)
AUTH_ACCESS_TTL_SECONDS=300
AUTH_REFRESH_TTL_SECONDS=86400

# Optional: seed the first admin on startup. If both are set AND that
# username does not exist, an admin user is created. Otherwise no-op.
# AUTH_INITIAL_ADMIN_USERNAME=root
# AUTH_INITIAL_ADMIN_PASSWORD=replace-me-with-a-strong-password
